# OpenAI profile — copy to .env when switching from MiniMax.
# For MiniMax defaults, see .env.example instead.
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
SEARCH_ROOT=data/samples/zoology
FILE_SEARCH_ROOT=data/samples/zoology
MICROSOFT_LEARN_MCP_URL=https://learn.microsoft.com/api/mcp
MS_ANSWER_MAX_CHARS=2000
